              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error is descriptive', () => pm.expect(pm.response.json().error).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/compare",
            "body": { "mode": "raw", "raw": "{\"player1\": \"Messi\", \"sport\": \"football\"}" }
          }
