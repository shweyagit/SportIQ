{
  "info": {
    "name": "SportIQ AI Platform API",
    "description": "Complete test suite for the SportIQ AI-powered sports analysis platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000", "type": "string" },
    { "key": "token", "value": "", "type": "string", "description": "Supabase JWT token" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is ok', () => pm.expect(pm.response.json().status).to.eql('ok'));",
                  "pm.test('Service name is correct', () => pm.expect(pm.response.json().service).to.eql('SportIQ API'));",
                  "pm.test('Response time < 500ms', () => pm.expect(pm.response.responseTime).to.be.below(500));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Analyse",
      "item": [
        {
          "name": "Dual Analyst - Football",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has analystA response', () => pm.expect(json.analystA).to.be.a('string').and.not.empty);",
                  "pm.test('Has analystB response', () => pm.expect(json.analystB).to.be.a('string').and.not.empty);",
                  "pm.test('Sport matches request', () => pm.expect(json.sport).to.eql('football'));",
                  "pm.test('Question echoed back', () => pm.expect(json.question).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/analyse",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Is Mbappe worth his transfer fee?\",\n  \"sport\": \"football\"\n}"
            }
          }
        },
        {
          "name": "Dual Analyst - Cricket",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Sport is cricket', () => pm.expect(pm.response.json().sport).to.eql('cricket'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/analyse",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Is Virat Kohli mentally the toughest batter ever?\",\n  \"sport\": \"cricket\"\n}"
            }
          }
        },
        {
          "name": "Dual Analyst - Tennis",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Sport is tennis', () => pm.expect(pm.response.json().sport).to.eql('tennis'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/analyse",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"Could peak Federer beat Djokovic on any surface?\",\n  \"sport\": \"tennis\"\n}"
            }
          }
        },
        {
          "name": "[Negative] Missing question field",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error message present', () => pm.expect(pm.response.json().error).to.include('question'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/analyse",
            "body": { "mode": "raw", "raw": "{\"sport\": \"football\"}" }
          }
        },
        {
          "name": "[Negative] Invalid sport",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error mentions sport', () => pm.expect(pm.response.json().error).to.include('sport'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/analyse",
            "body": { "mode": "raw", "raw": "{\"question\": \"Test\", \"sport\": \"basketball\"}" }
          }
        }
