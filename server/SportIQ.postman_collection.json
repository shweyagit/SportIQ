    {
      "name": "Timeline",
      "item": [
        {
          "name": "Career Timeline - Cristiano Ronaldo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has player name', () => pm.expect(json.name).to.be.a('string'));",
                  "pm.test('Has events array', () => pm.expect(json.events).to.be.an('array'));",
                  "pm.test('Has at least 5 events', () => pm.expect(json.events.length).to.be.at.least(5));",
                  "pm.test('Each event has year', () => json.events.forEach(e => pm.expect(e.year).to.match(/\\d{4}/)));",
                  "pm.test('Each event has type', () => json.events.forEach(e => pm.expect(['debut','transfer','trophy','milestone','retirement']).to.include(e.type)));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/timeline",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Cristiano Ronaldo\",\n  \"sport\": \"football\"\n}" }
          }
        },
