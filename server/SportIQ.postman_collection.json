    {
      "name": "Player",
      "item": [
        {
          "name": "Player Profile - Messi",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has player name', () => pm.expect(json.name).to.be.a('string').and.not.empty);",
                  "pm.test('Has nationality', () => pm.expect(json.nationality).to.be.a('string'));",
                  "pm.test('Has achievements array', () => pm.expect(json.achievements).to.be.an('array').and.not.empty);",
                  "pm.test('Has key stats array', () => pm.expect(json.keyStats).to.be.an('array'));",
                  "pm.test('Has career summary', () => pm.expect(json.careerSummary).to.be.a('string').and.not.empty);",
                  "pm.test('Has legacy quote', () => pm.expect(json.legacyQuote).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/player",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Lionel Messi\",\n  \"sport\": \"football\"\n}" }
          }
        },
        {
          "name": "Player Profile - Virat Kohli",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has player data', () => pm.expect(pm.response.json().name).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/player",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Virat Kohli\",\n  \"sport\": \"cricket\"\n}" }
          }
        },
        {
          "name": "Player Image - Cristiano Ronaldo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Image URL returned', () => pm.expect(json.image).to.be.a('string'));",
                  "pm.test('Image is a valid URL', () => pm.expect(json.image).to.match(/^https?:\\/\\//));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/player/image?name=Cristiano Ronaldo", "host": ["{{baseUrl}}"], "path": ["api","player","image"], "query": [{"key":"name","value":"Cristiano Ronaldo"}] }
          }
        },
        {
          "name": "[Negative] Missing name",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error mentions name', () => pm.expect(pm.response.json().error).to.include('name'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/player",
            "body": { "mode": "raw", "raw": "{\"sport\": \"football\"}" }
          }
        },
        {
          "name": "[Negative] Image not found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400 or 404', () => pm.expect([400,404]).to.include(pm.response.code));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/player/image", "host": ["{{baseUrl}}"], "path": ["api","player","image"] }
          }
        }
      ]
    },
    {
      "name": "Compare",
      "item": [
        {
          "name": "Head to Head - Messi vs Ronaldo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has player1 data', () => pm.expect(json.player1).to.be.an('object'));",
                  "pm.test('Has player2 data', () => pm.expect(json.player2).to.be.an('object'));",
                  "pm.test('Has verdict', () => pm.expect(json.verdict).to.be.a('string').and.not.empty);",
                  "pm.test('Has winner', () => pm.expect(json.winner).to.be.a('string').and.not.empty);",
                  "pm.test('Player1 has rating', () => pm.expect(json.player1.rating).to.match(/\\d+\\/10/));",
                  "pm.test('Player1 has strengths', () => pm.expect(json.player1.strengths).to.be.an('array').and.not.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/compare",
            "body": { "mode": "raw", "raw": "{\n  \"player1\": \"Lionel Messi\",\n  \"player2\": \"Cristiano Ronaldo\",\n  \"sport\": \"football\"\n}" }
          }
        },
