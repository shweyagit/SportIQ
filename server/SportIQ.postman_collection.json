                  "pm.test('Has verdict', () => pm.expect(pm.response.json().verdict).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/compare",
            "body": { "mode": "raw", "raw": "{\n  \"player1\": \"Virat Kohli\",\n  \"player2\": \"Sachin Tendulkar\",\n  \"sport\": \"cricket\"\n}" }
          }
        },
